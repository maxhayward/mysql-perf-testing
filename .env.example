# Copy to .env to override the docker-compose defaults baked into config.py.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=bench
MYSQL_PASSWORD=benchpw
MYSQL_DB=bench
BENCH_TABLE=bench

# --- Snowflake load target (only needed for --target snowflake) ---
# SNOWFLAKE_ACCOUNT=xy12345.eu-west-1
# SNOWFLAKE_USER=loader
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=BENCH
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_ROLE=LOADER
# Auth: prefer key-pair (Snowflake is phasing out single-factor passwords).
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
# ...or password:
# SNOWFLAKE_PASSWORD=
